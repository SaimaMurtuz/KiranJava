public class LoanSystem {
    public static void main(String[] args) {
        
        int age = 25;
        int monthlySalary = 35000;

        if (age >= 18 && age <= 60) {
            
            System.out.println("Age is valid. Checking salary...");

            if (monthlySalary >= 30000) {
                System.out.println("Congrats! You are eligible for a 10 Lakh Loan.");
            } 
            else if (monthlySalary >= 15000) {
                System.out.println("Congrats! You are eligible for a 2 Lakh Loan.");
            } 
            else {
                System.out.println("Sorry, your salary is too low for a loan.");
            }

        } else {
            System.out.println("Loan Rejected: Age must be between 18 and 60.");
        }
    }
}
